# Application
APP_PORT=3000
APP_ENV=development        # development | production (production hides internal error detail)
LOG_LEVEL=info             # debug | info | warn | error

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gdcpay_tasks
DB_SSLMODE=disable

# Auth
JWT_SECRET=jawa-adalah-kunci
JWT_EXPIRY=24h             # Go duration (e.g. 24h, 30m) or plain integer = hours

# Idempotency
IDEMPOTENCY_TTL=24h        # how long an Idempotency-Key is remembered
